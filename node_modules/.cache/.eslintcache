eprecatedRules":"34"},"C:\\Users\\npope\\OneDrive\\Desktop\\wowimnick.github.io\\src\\index.js",[],[],[],"C:\\Users\\npope\\OneDrive\\Desktop\\wowimnick.github.io\\src\\App.js",["35","36","37"],[],"C:\\Users\\npope\\OneDrive\\Desktop\\wowimnick.github.io\\src\\reportWebVitals.js",[],[],"C:\\Users\\npope\\OneDrive\\Desktop\\wowimnick.github.io\\src\\animations.js",["38","39","40","41","42"],[],"C:\\Users\\npope\\OneDrive\\Desktop\\wowimnick.github.io\\src\\descriptions.js",[],[],"C:\\Users\\npope\\OneDrive\\Desktop\\wowimnick.github.io\\src\\background.js",["43","44"],[],"import React, { Component } from 'react';\r\nimport * as d3 from 'd3';\r\n\r\nclass BlurredBackground extends Component {\r\n  componentDidMount() {\r\n    this.createBubbles();\r\n  }\r\n\r\n  createBubbles() {\r\n    const container = d3.select('.container');\r\n    const width = container.node().getBoundingClientRect().width;\r\n    const height = container.node().getBoundingClientRect().height;\r\n\r\n    const svg = container.append('svg')\r\n      .attr('width', width)\r\n      .attr('height', height)\r\n      .style('position', 'absolute')\r\n      .style('top', 0)\r\n      .style('left', 0)\r\n      .style('z-index', -2);\r\n\r\n    const bubbleCount = 5;\r\n    const bubbleData = d3.range(bubbleCount).map(() => {\r\n      return {\r\n        x: Math.random() * width,\r\n        y: Math.random() * height,\r\n        radius: Math.random() * 100 + 300,\r\n        gradientColor: d3.scaleLinear()\r\n          .domain([0, 1])\r\n          .range([\r\n            `rgba(${Math.floor(Math.random() * 255)}, ${Math.floor(Math.random() * 255)}, ${Math.floor(Math.random() * 255)}, 1)`,\r\n            `rgba(${Math.floor(Math.random() * 255)}, ${Math.floor(Math.random() * 255)}, ${Math.floor(Math.random() * 255)}, 0)`\r\n          ]),\r\n      }\r\n    });\r\n\r\n    const bubbles = svg.selectAll('circle')\r\n      .data(bubbleData)\r\n      .enter()\r\n      .append('circle')\r\n      .attr('cx', d => d.x)\r\n      .attr('cy', d => d.y)\r\n      .attr('r', d => d.radius)\r\n      .style('fill', d => `url(#gradient-${d.radius})`);\r\n\r\n    const update = () => {\r\n      bubbles.data(bubbleData)\r\n        .transition()\r\n        .duration(10000)\r\n        .ease(d3.easeQuadInOut)\r\n        .attr('cx', d => Math.random() * width)\r\n        .attr('cy', d => Math.random() * height)\r\n        .styleTween('fill', function(d) {\r\n          const i = d3.interpolateRgb(\r\n            d.gradientColor(0),\r\n            d.gradientColor(1)\r\n          );\r\n          return t => {\r\n            const color = i(t);\r\n            return `url(#gradient-${d.radius})`;\r\n          }\r\n        })\r\n        .on('end', update);\r\n    }\r\n\r\n    bubbleData.forEach(d => {\r\n      const gradient = svg.append('defs')\r\n        .append('radialGradient')\r\n        .attr('id', `gradient-${d.radius}`)\r\n        .attr('cx', '50%')\r\n        .attr('cy', '50%')\r\n        .attr('r', '40%')\r\n        .selectAll('stop')\r\n        .data([\r\n          { offset: '1%', color: d.gradientColor(0) },\r\n          { offset: '99%', color: d.gradientColor(1) }\r\n        ])\r\n        .enter()\r\n        .append('stop')\r\n        .attr('offset', d => d.offset)\r\n        .attr('stop-color', d => d.color);\r\n    });\r\n\r\n    update();\r\n  }\r\n\r\n  render() {\r\n    return (\r\n      <div className=\"container\">\r\n      </div>\r\n    );\r\n  }\r\n}\r\n\r\nexport default BlurredBackground;",[],{"ruleId":"45","severity":1,"message":"46","line":148,"column":17,"nodeType":"47","endLine":148,"endColumn":110},{"ruleId":"45","severity":1,"message":"46","line":152,"column":17,"nodeType":"47","endLine":152,"endColumn":114},{"ruleId":"45","severity":1,"message":"46","line":156,"column":17,"nodeType":"47","endLine":156,"endColumn":112},{"ruleId":"48","severity":1,"message":"49","line":34,"column":3,"nodeType":"50","messageId":"51","endLine":258,"endColumn":4},{"ruleId":"52","severity":1,"message":"53","line":329,"column":9,"nodeType":"54","messageId":"55","endLine":329,"endColumn":21},{"ruleId":"52","severity":1,"message":"53","line":340,"column":9,"nodeType":"54","messageId":"55","endLine":340,"endColumn":21},{"ruleId":"52","severity":1,"message":"53","line":351,"column":9,"nodeType":"54","messageId":"55","endLine":351,"endColumn":21},{"ruleId":"52","severity":1,"message":"53","line":362,"column":9,"nodeType":"54","messageId":"55","endLine":362,"endColumn":21},{"ruleId":"52","severity":1,"message":"56","line":59,"column":19,"nodeType":"54","messageId":"55","endLine":59,"endColumn":24},{"ruleId":"52","severity":1,"message":"57","line":67,"column":13,"nodeType":"54","messageId":"55","endLine":67,"endColumn":21},"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","default-case","Expected a default case.","SwitchStatement","missingDefaultCase","no-unused-vars","'screenHeight' is assigned a value but never used.","Identifier","unusedVar","'color' is assigned a value but never used.","'gradient' is assigned a value but never used."]